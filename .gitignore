# ── OSRM ──────────────────────────────────────────────────────────────────────
# Compiled graph artifacts (generated by docker-compose osrm-setup on first run)
osrm-clm/**/*.osrm
osrm-clm/**/*.osrm.*
# Per-profile directories are created by the setup script (contain PBF copies + graphs)
osrm-clm/car/
osrm-clm/bike/
osrm-clm/foot/
# Root-level OSM PBF is tracked via LFS (.gitattributes)

# ── OTP ───────────────────────────────────────────────────────────────────────
# graph.obj and the 2026 GTFS zip are tracked via LFS
otp-toledo/GTFS_Urbano_Toledo.zip
otp-toledo/GTFS_Urbano_Toledo_2026/
otp-toledo/*.osm.pbf
otp-toledo/graphs/

# ── Backend GTFS ──────────────────────────────────────────────────────────────
# Auto-extracted from LFS zip by docker-compose gtfs-init on first run
movilidad-urbana-sim/backend/data/

# ── LPMC notebooks ────────────────────────────────────────────────────────────
# Development notebooks (pipeline covered by lpmc/*.py scripts)
lpmc/notebooks/

# ── LPMC data ─────────────────────────────────────────────────────────────────
# Private dataset — not redistributable
lpmc/data/raw/
lpmc/data/processed/
lpmc/data/preprocessed/
LPMC_dataset(in).csv

# ── LPMC models ───────────────────────────────────────────────────────────────
# Active models (xgb_lpmc.joblib, dnn_lpmc.*) are tracked via LFS (.gitattributes)
# RF is optional — train locally with: python lpmc/04_train_rf.py
lpmc/models/rf_lpmc.joblib
lpmc/models/rf_lpmc_scaler.joblib
# Old / backup model variants (superseded by xgb_lpmc.joblib)
lpmc/models/xgb_lpmc_baseline*.joblib
lpmc/models/xgb_lpmc_tuned.joblib
lpmc/models/xgb_lpmc_tuned_nohh.joblib
lpmc/models/xgb_lpmc_tuned_withhh*.joblib
lpmc/models/xgb_lpmc_scaler_nohh.joblib
lpmc/models/xgb_lpmc_scaler_withhh*.joblib
lpmc/models/dnn_lpmc_exploding_weights*

